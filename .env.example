# Tartography environment variables — copy to .env.local and fill in real values.

# Browser key, referrer-restricted, Maps JavaScript API only. Shipped to the client.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-maps-key

# Server-only key, Places API only. Used exclusively by scripts/seed.ts. Never expose to the browser.
GOOGLE_PLACES_SERVER_KEY=your-server-places-key

# Supabase project URL and anon (public) key — safe for the client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server/seed script only. Bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
